PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/shopnest

# JWT — keep secret long & random (openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_min_32_chars

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Gmail (App Password — NOT your main Gmail password)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_gmail_app_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://localhost

# Seed script — REQUIRED, no default. Set a strong password before running npm run seed
ADMIN_PASSWORD=
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@shopnest.com
ADMIN_ROLE=admin

# Docker Compose credentials (used in docker-compose.yml via ${VAR} syntax)
MONGO_ROOT_USER=shopnest
MONGO_ROOT_PASS=changeme_in_production
RABBITMQ_USER=shopnest
RABBITMQ_PASS=changeme_in_production
