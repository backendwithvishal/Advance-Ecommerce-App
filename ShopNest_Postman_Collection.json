    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products (No Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{endpoint}}/api/products?page=1&limit=20",
              "host": ["{{endpoint}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Products (With Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{endpoint}}/api/products?category=Electronics&minPrice=50&maxPrice=500&page=1&limit=10",
              "host": ["{{endpoint}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "Electronics" },
                { "key": "minPrice", "value": "50" },
                { "key": "maxPrice", "value": "500" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{endpoint}}/api/products?search=headphones",
              "host": ["{{endpoint}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "search", "value": "headphones" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "  pm.collectionVariables.set('productId', res._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{endpoint}}/api/products/{{productId}}",
              "host": ["{{endpoint}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          },
          "response": []
        },
        {
          "name": "ADMIN -- Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "  pm.collectionVariables.set('productId', res._id);",
                  "  console.log('productId saved:', res._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Wireless Headphones", "type": "text" },
                { "key": "description", "value": "Premium noise-cancelling headphones", "type": "text" },
                { "key": "price", "value": "299.99", "type": "text" },
                { "key": "category", "value": "Electronics", "type": "text" },
                { "key": "stock", "value": "50", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{endpoint}}/api/products",
              "host": ["{{endpoint}}"],
              "path": ["api", "products"]
            }
          },
          "response": []
        },
        {
          "name": "ADMIN -- Update Product",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Product Name", "type": "text" },
                { "key": "price", "value": "149.99", "type": "text" },
                { "key": "stock", "value": "100", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{endpoint}}/api/products/{{productId}}",
              "host": ["{{endpoint}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          },
          "response": []
        },
        {
          "name": "ADMIN -- Delete Product",
          "request": {
            "auth": {
