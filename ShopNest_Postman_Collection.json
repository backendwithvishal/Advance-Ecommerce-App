    {
      "name": "User Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  pm.collectionVariables.set('userId', res._id);",
                  "  pm.environment.set('token', res.token);",
                  "  pm.environment.set('refreshToken', res.refreshToken);",
                  "  pm.environment.set('userId', res._id);",
                  "  console.log('Registered. Token and userId saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"pass123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{endpoint}}/api/auth/register",
              "host": ["{{endpoint}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
