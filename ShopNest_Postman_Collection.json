    {
      "name": "Payment",
      "item": [
        {
          "name": "1. Create Razorpay Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('razorpayOrderId', res.id);",
                  "  console.log('Razorpay Order ID saved:', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{endpoint}}/api/payment/order",
              "host": ["{{endpoint}}"],
              "path": ["api", "payment", "order"]
            }
          },
          "response": []
        },
        {
          "name": "2. Confirm Payment (with HMAC signature)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "console.log('Confirm Payment response:', JSON.stringify(res));",
                  "if (res.order && res.order._id) {",
                  "  console.log('Order status:', res.order.status);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"{{razorpayOrderId}}\",\n  \"razorpay_payment_id\": \"{{razorpayPaymentId}}\",\n  \"razorpay_signature\": \"{{razorpaySignature}}\",\n  \"orderId\": \"{{orderId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{endpoint}}/api/payment/confirm",
              "host": ["{{endpoint}}"],
              "path": ["api", "payment", "confirm"]
            }
          },
          "response": []
        },
        {
          "name": "3. Verify Payment Signature (Standalone)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
