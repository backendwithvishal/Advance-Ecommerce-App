              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{endpoint}}/api/payment/verify",
              "host": ["{{endpoint}}"],
              "path": ["api", "payment", "verify"]
            }
          },
          "response": []
        }
      ]
