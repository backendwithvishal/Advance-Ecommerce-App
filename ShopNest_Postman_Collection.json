              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', '');",
                  "  pm.collectionVariables.set('refreshToken', '');",
                  "  console.log('Logged out. Tokens cleared.');",
                  "}"
                ],
